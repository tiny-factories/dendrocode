{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/cron/refresh-popular-gallery.js": {
      "maxDuration": 60
    },
    "api/tree/[slug].js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-popular-gallery",
      "schedule": "0 6 * * 1"
    }
  ]
}
